{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./playwright-out",
    "rootDir": "."
  },
  "include": ["playwright/**/*.ts", "tests/**/*.ts", "playwright.config.ts"]
}
